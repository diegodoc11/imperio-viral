# Apify API token — get it from https://console.apify.com/settings/integrations
# IMPORTANT: rotate any token that has been shared in chats or pasted publicly.
APIFY_TOKEN=

# OpenAI API key — only needed for Whisper transcriptions (Phase 5)
OPENAI_API_KEY=

# SQLite database file (relative to project root)
DATABASE_PATH=./data/content.db
